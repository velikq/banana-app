{
  "name": "bananaImageProDelux",
  "version": "1.1.0",
  "description": "Локальное приложение для генерации и редактирования изображений",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win nsis"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^24.10.1",
    "electron": "^39.2.4",
    "electron-builder": "^26.0.12"
  },
  "dependencies": {
    "@google/genai": "^1.30.0",
    "dotenv": "^17.2.3",
    "exifr": "^7.1.3",
    "mime": "^4.1.0",
    "piexifjs": "^1.0.6"
  },
  "allowScripts": {
    "electron@39.8.7": true
  },
  "build": {
    "appId": "com.banana.pots.provip",
    "productName": "banana.pots pro-vip",
    "electronDist": "node_modules/electron/dist",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "index.html",
      "renderer.js",
      "styles.css",
      "lib/**/*",
      "providers/**/*",
      "package.json",
      "!docs/**/*",
      "!input/**/*",
      "!output/**/*",
      "!projects/**/*",
      "!config.json",
      "!*.md",
      "!*.txt",
      "!*.png"
    ],
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
